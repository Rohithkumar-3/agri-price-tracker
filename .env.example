# Commodity Market Intelligence Platform — Environment Config
# Copy this file to .env and fill in your values

# ── Agmarknet API (data.gov.in) ────────────────────────────────────────────
# Get your key at: https://data.gov.in → Login → My Account → API Keys
# Resource ID: 9ef84268-d588-465a-a308-a864a43d0070
AGMARKNET_API_KEY=your_key_here

# ── Anthropic API (for AI insights) ───────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here
